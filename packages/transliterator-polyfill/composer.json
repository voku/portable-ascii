{
    "name": "voku/transliterator-polyfill",
    "description": "Limited transliterator_transliterate() polyfill package backed by voku/portable-ascii.",
    "type": "library",
    "keywords": [
        "php",
        "transliterator",
        "polyfill",
        "icu",
        "ascii"
    ],
    "homepage": "https://github.com/voku/transliterator-polyfill",
    "license": "MIT",
    "authors": [
        {
            "name": "Lars Moelleken",
            "homepage": "https://www.moelleken.org/"
        }
    ],
    "require": {
        "php": ">=7.1.0",
        "voku/portable-ascii": "^2.1"
    },
    "require-dev": {
        "phpunit/phpunit": "~8.5 || ~9.6 || ~10.5 || ~11.5"
    },
    "autoload": {
        "psr-4": {
            "Voku\\Transliterator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Voku\\Transliterator\\Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../",
            "options": {
                "symlink": false,
                "versions": {
                    "voku/portable-ascii": "2.1.99"
                }
            }
        }
    ]
}
